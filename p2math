    <script>
        // --- Turso 數據庫連接配置 ---
        const TURSO_URL = "libsql://p3-math-yam2.aws-ap-northeast-1.turso.io";
        const TURSO_TOKEN = "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJhIjoicnciLCJpYXQiOjE3Nzk2OTQwMjAsImlkIjoiMDE5ZDk1MWUtZTgwMS03ZjU1LTg5OWUtZDI1YTVhNzY4MjU2IiwicmlkIjoiMmFlOTU2YTUtZTYxZi00Y2U0LTkxYTYtNmE3Mjg2NTc4ZDFkIn0.GiuVceCb8FLdMm8Ax3u6DXDh-0r-a-oeZFJU4nk49XX9K6d0SB859wdDnK-duai7wr701BeX4fyOdh9Vw09ZCA";
        
        // 將 libsql:// 轉為 https:// 格式以便進行 HTTP API 呼叫
        const TURSO_HTTP_URL = TURSO_URL.replace("libsql://", "https://");

        // --- 狀態變數 ---
        const GAME_DURATION = 45; // 遊戲時間 (秒)
        let timer;
        let timeLeft = 0;
        let score = 0;
        let currentNum1 = 0;
        let currentNum2 = 0;
        let currentAnswer = "";
        
        let studentClass = "";
        let studentId = "";

        // 下載快取的排名數據
        let cachedRecords = [];

        // --- DOM 元素參考 ---
        const screens = {
            login: document.getElementById('screen-login'),
            game: document.getElementById('screen-game'),
            result: document.getElementById('screen-result'),
            records: document.getElementById('screen-records')
        };
        const appContainer = document.getElementById('app-container');
        const answerBox = document.getElementById('answer-box');
        
        // --- 頁面初始設定 ---
        window.onload = function() {
            // 初始化數據庫表格
            initDatabaseTable();
        };

        // --- 導航控制 ---
        function showScreen(screenName) {
            for (let key in screens) {
                screens[key].classList.add('hidden');
            }
            screens[screenName].classList.remove('hidden');
        }

        function goHome() {
            showScreen('login');
        }

        // --- Turso HTTP API 核心請求封裝 ---
        async function executeTursoQuery(statements) {
            try {
                const response = await fetch(`${TURSO_HTTP_URL}/v2/pipeline`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${TURSO_TOKEN}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        requests: statements.map(sql => ({
                            type: 'execute',
                            stmt: { sql: sql }
                        }))
                    })
                });

                if (!response.ok) {
                    throw new Error(`HTTP 錯誤: ${response.status}`);
                }

                const data = await response.json();
                return data.results;
            } catch (error) {
                console.error("Turso 連接失敗:", error);
                throw error;
            }
        }

        // --- 初始化數據庫表格 (如果不存在則建立) ---
        async function initDatabaseTable() {
            const createTableSql = `
                CREATE TABLE IF NOT EXISTS multiplication_contest (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    class_name TEXT NOT NULL,
                    student_id INTEGER NOT NULL,
                    score INTEGER NOT NULL,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                );
            `;
            try {
                await executeTursoQuery([createTableSql]);
                console.log("數據表初始化成功或已存在");
            } catch (err) {
                console.error("無法初始化數據庫:", err);
            }
        }

        // --- 遊戲邏輯 ---
        function startGame() {
            // 獲取並驗證下拉選單
            studentClass = document.getElementById('input-class').value;
            studentId = document.getElementById('input-id').value;

            if (!studentClass || !studentId) {
                alert("請先選擇班別和學號！");
                return;
            }

            // 初始化遊戲狀態
            score = 0;
            timeLeft = GAME_DURATION;
            currentAnswer = "";
            
            document.getElementById('display-student').innerText = `${studentClass} - ${studentId} 號`;
            document.getElementById('score-display').innerText = score;
            updateTimerDisplay();
            
            showScreen('game');
            generateQuestion();
            updateAnswerBox();

            // 啟動計時器
            clearInterval(timer);
            timer = setInterval(() => {
                timeLeft--;
                updateTimerDisplay();
                
                if (timeLeft <= 0) {
                    endGame();
                }
            }, 1000);
        }

        function generateQuestion() {
            // 產生 2-9 之間的隨機數
            currentNum1 = Math.floor(Math.random() * 8) + 2; 
            currentNum2 = Math.floor(Math.random() * 8) + 2; 
            
            document.getElementById('num1').innerText = currentNum1;
            document.getElementById('num2').innerText = currentNum2;
            
            currentAnswer = "";
            updateAnswerBox();
        }

        function updateTimerDisplay() {
            document.getElementById('time-text').innerText = timeLeft;
            
            // 更新進度條寬度和顏色
            const percentage = (timeLeft / GAME_DURATION) * 100;
            const timeBar = document.getElementById('time-bar');
            timeBar.style.width = `${percentage}%`;
            
            if (percentage > 50) {
                timeBar.className = "h-4 transition-all duration-1000 ease-linear bg-green-500";
            } else if (percentage > 20) {
                timeBar.className = "h-4 transition-all duration-1000 ease-linear bg-yellow-400";
            } else {
                timeBar.className = "h-4 transition-all duration-1000 ease-linear bg-red-500";
            }
        }

        // --- 鍵盤輸入邏輯 ---
        function inputNum(num) {
            if (currentAnswer.length < 3) {
                currentAnswer += num.toString();
                updateAnswerBox();
            }
        }

        function clearInput() {
            currentAnswer = "";
            updateAnswerBox();
        }

        function deleteInput() {
            if (currentAnswer.length > 0) {
                currentAnswer = currentAnswer.slice(0, -1);
                updateAnswerBox();
            }
        }

        function updateAnswerBox() {
            answerBox.innerText = currentAnswer;
            if(currentAnswer === "") {
                answerBox.innerHTML = "&nbsp;"; 
            }
        }

        // --- 提交與判斷 ---
        function submitAnswer() {
            if (currentAnswer === "") return;

            const playerAns = parseInt(currentAnswer);
            const correctAns = currentNum1 * currentNum2;

            if (playerAns === correctAns) {
                score++;
                document.getElementById('score-display').innerText = score;
                
                appContainer.classList.add('correct-flash');
                setTimeout(() => { appContainer.classList.remove('correct-flash'); }, 300);
                
                generateQuestion();
            } else {
                answerBox.classList.add('shake', 'text-red-500', 'border-red-500');
                answerBox.classList.remove('text-blue-600', 'border-gray-800');
                
                setTimeout(() => {
                    answerBox.classList.remove('shake', 'text-red-500', 'border-red-500');
                    answerBox.classList.add('text-blue-600', 'border-gray-800');
                    clearInput();
                }, 400);
            }
        }

        // --- 結束與數據庫同步 ---
        function endGame() {
            clearInterval(timer);
            
            document.getElementById('result-student-info').innerText = `${studentClass} - ${studentId} 號`;
            document.getElementById('final-score').innerText = score;
            
            showScreen('result');
            
            // 執行數據庫寫入
            uploadScoreToTurso(studentClass, parseInt(studentId), score);
        }

        async function uploadScoreToTurso(cls, id, scr) {
            const statusDiv = document.getElementById('upload-status');
            statusDiv.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> 正在上傳至雲端數據庫...`;
            statusDiv.className = "mb-6 flex items-center justify-center gap-2 text-sm font-bold text-blue-500";

            // 在 2026-05-25 的背景下獲取當前時間格式
            const timestamp = new Date().toISOString();
            const insertSql = `
                INSERT INTO multiplication_contest (class_name, student_id, score, created_at)
                VALUES ('${cls}', ${id}, ${scr}, '${timestamp}');
            `;

            try {
                await executeTursoQuery([insertSql]);
                statusDiv.innerHTML = `<i class="fa-solid fa-circle-check text-green-500"></i> 上傳成功！已同步至雲端`;
                statusDiv.className = "mb-6 flex items-center justify-center gap-2 text-sm font-bold text-green-600";
            } catch (err) {
                console.error("上傳失敗:", err);
                statusDiv.innerHTML = `<i class="fa-solid fa-circle-exclamation text-red-500"></i> 上傳失敗！暫存於本機。`;
                statusDiv.className = "mb-6 flex items-center justify-center gap-2 text-sm font-bold text-red-600";
                
                // 本機備份儲存 (以防萬一斷網)
                let localBackups = JSON.parse(localStorage.getItem('turso_backups')) || [];
                localBackups.push({ class_name: cls, student_id: id, score: scr, created_at: timestamp });
                localStorage.setItem('turso_backups', JSON.stringify(localBackups));
            }
        }

        // --- 管理員密碼保護功能 ---
        function promptAdminPassword() {
            document.getElementById('admin-pwd-input').value = "";
            document.getElementById('pwd-error-msg').classList.add('hidden');
            document.getElementById('modal-password').classList.remove('hidden');
        }

        function closePasswordModal() {
            document.getElementById('modal-password').classList.add('hidden');
        }

        function verifyAdminPassword() {
            const pwdInput = document.getElementById('admin-pwd-input').value;
            if (pwdInput === "admin1234") {
                closePasswordModal();
                fetchRecordsFromTurso(); // 通過驗證後下載數據
            } else {
                document.getElementById('pwd-error-msg').classList.remove('hidden');
            }
        }

        // 支援管理員密碼輸入框按 Enter 鍵確認
        document.getElementById('admin-pwd-input')?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') verifyAdminPassword();
        });

        // --- 從 Turso 下載所有紀錄 ---
        async function fetchRecordsFromTurso() {
            showScreen('records');
            const tbody = document.getElementById('records-table-body');
            tbody.innerHTML = `
                <tr>
                    <td colspan="4" class="p-8 text-center text-gray-500 font-bold">
                        <i class="fa-solid fa-spinner animate-spin mr-2"></i> 正在載入雲端數據...
                    </td>
                </tr>
            `;

            const selectSql = `SELECT class_name, student_id, score, created_at FROM multiplication_contest;`;
            try {
                const results = await executeTursoQuery([selectSql]);
                const resultObj = results[0];
                
                if (resultObj && resultObj.active && resultObj.response && resultObj.response.rows) {
                    const rows = resultObj.response.rows;
                    const cols = resultObj.response.cols;

                    // 將 rows 陣列轉成好處理的物件格式
                    cachedRecords = rows.map(row => {
                        let record = {};
                        row.forEach((val, i) => {
                            // 獲取欄位名，根據格式進行轉換
                            const colName = cols[i].name;
                            record[colName] = val.value !== undefined ? val.value : val;
                        });
                        return record;
                    });
                } else {
                    cachedRecords = [];
                }

                renderRecordsList();

            } catch (err) {
                console.error("載入排名失敗:", err);
                tbody.innerHTML = `
                    <tr>
                        <td colspan="4" class="p-8 text-center text-red-500 font-bold">
                            <i class="fa-solid fa-circle-exclamation mr-2"></i> 載入失敗，請檢查網路連線。
                        </td>
                    </tr>
                `;
            }
        }

        // --- 渲染並排序、篩選排名清單 ---
        function renderRecordsList() {
            const tbody = document.getElementById('records-table-body');
            const noRecordsMsg = document.getElementById('no-records-msg');
            const filterClass = document.getElementById('filter-class').value;
            const sortBy = document.getElementById('sort-by').value;

            // 1. 篩選數據
            let displayData = [...cachedRecords];
            if (filterClass !== "ALL") {
                displayData = displayData.filter(item => item.class_name === filterClass);
            }

            // 2. 排序數據
            if (sortBy === "score_desc") {
                // 先按分數排，分數相同再按時間排序（先達成的在前）
                displayData.sort((a, b) => {
                    const scoreA = parseInt(a.score);
                    const scoreB = parseInt(b.score);
                    if (scoreB !== scoreA) {
                        return scoreB - scoreA;
                    }
                    return new Date(a.created_at) - new Date(b.created_at);
                });
            } else if (sortBy === "time_desc") {
                displayData.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
            } else if (sortBy === "time_asc") {
                displayData.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
            }

            // 3. 渲染至畫面上
            tbody.innerHTML = '';
            
            if (displayData.length === 0) {
                noRecordsMsg.classList.remove('hidden');
                return;
            }
            noRecordsMsg.classList.add('hidden');

            displayData.forEach((row, index) => {
                // 本地時區轉換
                const utcDate = new Date(row.created_at);
                const localTimeStr = isNaN(utcDate.getTime()) ? '未知時間' : 
                    `${utcDate.getMonth() + 1}/${utcDate.getDate()} ${utcDate.getHours().toString().padStart(2, '0')}:${utcDate.getMinutes().toString().padStart(2, '0')}`;

                // 排名標章與文字特效
                let rankMarkup = `${index + 1}`;
                if (sortBy === "score_desc") {
                    if (index === 0) rankMarkup = `<span class="bg-yellow-400 text-white rounded-full w-7 h-7 inline-flex items-center justify-center font-black shadow-sm"><i class="fa-solid fa-trophy text-xs"></i></span>`;
                    else if (index === 1) rankMarkup = `<span class="bg-slate-300 text-white rounded-full w-7 h-7 inline-flex items-center justify-center font-black shadow-sm">2</span>`;
                    else if (index === 2) rankMarkup = `<span class="bg-amber-600 text-white rounded-full w-7 h-7 inline-flex items-center justify-center font-black shadow-sm">3</span>`;
                }

                const scoreHighlight = parseInt(row.score) >= 15 ? 'text-green-600 font-black' : 'text-gray-800 font-bold';

                const tr = document.createElement('tr');
                tr.className = index % 2 === 0 ? 'bg-white' : 'bg-gray-50';
                tr.innerHTML = `
                    <td class="p-3 border-b text-center font-bold text-gray-500">${rankMarkup}</td>
                    <td class="p-3 border-b text-center font-extrabold text-gray-800">${row.class_name} - ${row.student_id}號</td>
                    <td class="p-3 border-b text-center text-lg ${scoreHighlight}">${row.score} 題</td>
                    <td class="p-3 border-b text-center text-xs text-gray-400 font-semibold">${localTimeStr}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        // --- 清空資料庫全部記錄確認 ---
        async function clearRecordsConfirm() {
            const verifyText = prompt("注意！這會永久刪除雲端資料庫中的所有學生成績記錄！\n\n如果確定，請在下方輸入： DELETE");
            if (verifyText === "DELETE" || verifyText === "delete") {
                const deleteSql = `DELETE FROM multiplication_contest;`;
                try {
                    await executeTursoQuery([deleteSql]);
                    alert("資料庫已成功清空！");
                    fetchRecordsFromTurso(); // 重新整理清單
                } catch (err) {
                    alert("刪除失敗，請檢查網絡連線或權限設定！");
                }
            } else if (verifyText !== null) {
                alert("輸入錯誤，取消操作。");
            }
        }

        // --- 實體鍵盤支援 ---
        document.addEventListener('keydown', (e) => {
            if (screens.game.classList.contains('hidden')) return; // 只在遊戲中有效
            
            if (e.key >= '0' && e.key <= '9') {
                inputNum(parseInt(e.key));
            } else if (e.key === 'Backspace') {
                deleteInput();
            } else if (e.key === 'Enter') {
                submitAnswer();
            } else if (e.key === 'Escape' || e.key === 'Delete') {
                clearInput();
            }
        });

    </script>
